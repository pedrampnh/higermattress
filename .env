# Copy this file to .env and fill in your real values before going live.

# Port the server listens on
PORT=3000

# Public base URL of your deployed site (used to build the ZarinPal callback URL)
# e.g. https://higermattress.com
BASE_URL=http://localhost:3000

# Session cookie signing secret — set a long random string in production
SESSION_SECRET=change-this-to-a-long-random-string

# ZarinPal
# Set to "false" once you have a real merchant id and are ready to accept live payments
ZARINPAL_SANDBOX=true
# Your real 36-character merchant id from your ZarinPal dashboard
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000

# WhatsApp number kept only as a fallback support link (with country code, no +)
SUPPORT_WHATSAPP=989120000000
SUPPORT_PHONE=021-12345678

# Password to access the admin panel at /admin — change this before going live!
ADMIN_PASSWORD=higer-admin
