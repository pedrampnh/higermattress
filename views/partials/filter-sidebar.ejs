<%
  // تعیین اینکه آیا فیلتری فعال است یا نه — برای نمایش دکمه پاک کردن
  const hasFilter = (selectedCategories && selectedCategories.length > 0) || sizeCategory || priceBucket;
%>

<aside class="filter-sidebar" id="filterSidebar">
  <form method="GET" action="/products" id="filterForm">

    <!-- ====== لایه‌بندی ====== -->
    <h3>لایه‌بندی</h3>

    <!-- گروه فنری -->
    <div class="filter-section">
      <div class="filter-section-header" onclick="toggleFilterSection(this)">
        <span>فنری</span>
        <span class="filter-section-arrow">›</span>
      </div>
      <div class="filter-section-body open">
        <label class="filter-check">
          <input type="checkbox" name="category" value="spring-pocket"
            <%= selectedCategories.includes('spring-pocket') ? 'checked' : '' %>>
          فنر منفصل
        </label>
        <label class="filter-check">
          <input type="checkbox" name="category" value="spring-bonnell"
            <%= selectedCategories.includes('spring-bonnell') ? 'checked' : '' %>>
          فنر متصل
        </label>
      </div>
    </div>

    <!-- گروه بدون فنر -->
    <div class="filter-section">
      <div class="filter-section-header" onclick="toggleFilterSection(this)">
        <span>بدون فنر</span>
        <span class="filter-section-arrow">›</span>
      </div>
      <div class="filter-section-body open">
        <label class="filter-check">
          <input type="checkbox" name="category" value="foam"
            <%= selectedCategories.includes('foam') ? 'checked' : '' %>>
          اسفنجی
        </label>
        <label class="filter-check">
          <input type="checkbox" name="category" value="memory-foam"
            <%= selectedCategories.includes('memory-foam') ? 'checked' : '' %>>
          مموری فوم
        </label>
      </div>
    </div>

    <!-- ====== سایز ====== -->
    <h3 style="margin-top:20px;">سایز</h3>
    <div class="filter-section">
      <div class="filter-section-body open">
        <% sizeCategories.forEach(function(sc){ %>
          <label class="filter-radio">
            <input type="radio" name="sizeCategory" value="<%= sc.slug %>"
              <%= sizeCategory === sc.slug ? 'checked' : '' %>>
            <%= sc.label %>
            <span style="font-size:0.72rem;color:var(--ink-500);margin-right:4px;">(<%= sc.sizeLabel %>)</span>
          </label>
        <% }); %>
        <label class="filter-radio">
          <input type="radio" name="sizeCategory" value=""
            <%= !sizeCategory ? 'checked' : '' %>>
          همه سایزها
        </label>
      </div>
    </div>

    <!-- ====== بازه قیمت ====== -->
    <h3 style="margin-top:20px;">بازه قیمت</h3>
    <div class="filter-section">
      <div class="filter-section-body open">
        <label class="filter-radio">
          <input type="radio" name="priceBucket" value=""
            <%= !priceBucket ? 'checked' : '' %>>
          همه قیمت‌ها
        </label>
        <label class="filter-radio">
          <input type="radio" name="priceBucket" value="under5"
            <%= priceBucket === 'under5' ? 'checked' : '' %>>
          زیر ۵ میلیون
        </label>
        <label class="filter-radio">
          <input type="radio" name="priceBucket" value="5to10"
            <%= priceBucket === '5to10' ? 'checked' : '' %>>
          ۵ تا ۱۰ میلیون
        </label>
        <label class="filter-radio">
          <input type="radio" name="priceBucket" value="10to20"
            <%= priceBucket === '10to20' ? 'checked' : '' %>>
          ۱۰ تا ۲۰ میلیون
        </label>
        <label class="filter-radio">
          <input type="radio" name="priceBucket" value="over20"
            <%= priceBucket === 'over20' ? 'checked' : '' %>>
          بالای ۲۰ میلیون
        </label>
      </div>
    </div>

    <!-- نگه داشتن sort -->
    <input type="hidden" name="sort" value="<%= sort || 'default' %>">

    <button type="submit" class="filter-apply-btn">اعمال فیلتر</button>

    <% if (hasFilter) { %>
      <a href="/products" class="filter-clear-link">پاک کردن فیلترها</a>
    <% } %>

  </form>
</aside>

<style>
/* بخش‌های داخل filter sidebar */
.filter-section{ margin-bottom:2px; }
.filter-section-header{
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 4px; cursor:pointer; font-size:0.83rem; font-weight:600; color:var(--ink-700);
  border-bottom:1px solid var(--linen-100);
  user-select:none;
}
.filter-section-header:hover{ color:var(--ink-900); }
.filter-section-arrow{ font-size:1rem; transition:transform .2s; display:inline-block; color:var(--ink-500); }
.filter-section-arrow.rotated{ transform:rotate(90deg); color:var(--honey-500); }
.filter-section-body{ padding:8px 0; display:none; }
.filter-section-body.open{ display:block; }
</style>

<script>
function toggleFilterSection(header) {
  const body = header.nextElementSibling;
  const arrow = header.querySelector('.filter-section-arrow');
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  arrow.classList.toggle('rotated', !isOpen);
}

// فیلتر خودکار با تغییر checkbox/radio
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('filterForm');
  if (form) {
    form.querySelectorAll('input[type="checkbox"], input[type="radio"]').forEach(function(input) {
      input.addEventListener('change', function() {
        form.submit();
      });
    });
  }

  // FIX: مطمئن می‌شیم sidebar همیشه sticky هست
  // این کد کاملاً اضافی هست، CSS کافیه، ولی برای اطمینان:
  const sidebar = document.getElementById('filterSidebar');
  if (sidebar) {
    sidebar.style.position = 'sticky';
    sidebar.style.top = '80px';
  }
});
</script>
