<%
/* Expects: sizeCategories (array), optional activeSlug */
var _activeSlug = typeof activeSlug !== 'undefined' ? activeSlug : '';

function sizeIcon(icon) {
  var head = '<circle cx="CX" cy="CY" r="7" fill="var(--linen-200)"/>';
  var pillow = '<rect x="PX" y="PY" width="34" height="20" rx="8" fill="var(--linen-100)"/>';
  var body = '<rect x="BX" y="BY" width="52" height="14" rx="7" fill="var(--linen-200)"/>';
  var arm = '<path d="M CX2,CY2 q14,-16 26,-4" stroke="var(--linen-200)" stroke-width="6" fill="none" stroke-linecap="round"/>';
  var base = '<rect x="10" y="86" width="100" height="14" rx="4" fill="var(--linen-100)"/>';

  function figure(x, scale) {
    scale = scale || 1;
    var s = 'transform="translate(' + x + ',' + (30 - 8*(scale-1)) + ') scale(' + scale + ')"';
    return '<g ' + s + '>' +
      '<rect x="0" y="0" width="30" height="17" rx="7" fill="var(--linen-100)"/>' +
      '<circle cx="34" cy="8" r="8" fill="var(--linen-200)"/>' +
      '<path d="M34,16 q12,-14 24,-3" stroke="var(--linen-200)" stroke-width="6" fill="none" stroke-linecap="round"/>' +
      '</g>';
  }

  var content = '';
  if (icon === 'family') {
    content = figure(2, 0.85) + figure(28, 1) + figure(56, 0.7);
  } else if (icon === 'double-large' || icon === 'double') {
    content = figure(6, 1) + figure(42, 1);
  } else if (icon === 'single-large' || icon === 'single') {
    content = figure(22, 1.1);
  } else if (icon === 'kids') {
    content = figure(22, 0.75);
  }

  return '<svg viewBox="0 0 120 108" xmlns="http://www.w3.org/2000/svg">' +
    base +
    content +
    '</svg>';
}
%>
<div class="size-cat-grid">
  <% sizeCategories.forEach(function(c){ %>
    <a class="size-cat-card<%= _activeSlug === c.slug ? ' is-active' : '' %>" href="/products?sizeCategory=<%= c.slug %>">
      <span class="size-cat-icon"><%- sizeIcon(c.icon) %></span>
      <span class="size-cat-name"><%= c.label %></span>
      <span class="size-cat-dim"><%= c.sizeLabel %></span>
    </a>
  <% }) %>
</div>
