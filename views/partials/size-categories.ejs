<%
  var activeSlug = typeof activeSlug !== 'undefined' ? activeSlug : '';

  function buildPersonSVG(icon) {
    var pillow = '<ellipse cx="13" cy="13" rx="12" ry="10" fill="none" stroke="currentColor" stroke-width="1.5"/>';
    var body = '<rect x="7" y="24" width="12" height="16" rx="4" fill="none" stroke="currentColor" stroke-width="1.5"/>';
    var arm1 = '<line x1="7" y1="27" x2="2" y2="34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
    var arm2 = '<line x1="19" y1="27" x2="24" y2="34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
    var legs = '<line x1="10" y1="40" x2="8" y2="50" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="16" y1="40" x2="18" y2="50" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
    function figure(x, scale) {
      scale = scale || 1;
      var s = 'transform="translate(' + x + ',' + (30 - 8*(scale-1)) + ') scale(' + scale + ')"';
      return '<g ' + s + '>' + pillow + body + arm1 + arm2 + legs + '</g>';
    }
    var content = '';
    if (icon === 'family') {
      content = figure(2, 0.85) + figure(28, 1) + figure(56, 0.7);
    } else if (icon === 'double-large' || icon === 'double') {
      content = figure(6, 1) + figure(42, 1);
    } else if (icon === 'single-large' || icon === 'single') {
      content = figure(22, 1.1);
    } else if (icon === 'kids') {
      content = figure(22, 0.75);
    }
    var base = '<rect x="0" y="72" width="86" height="6" rx="3" fill="currentColor" opacity="0.35"/>';
    return '<svg viewBox="0 0 86 80" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">' + base + content + '</svg>';
  }
%>

<div class="size-cats-grid">
  <% sizeCategories.forEach(function(sc){ %>
    <a href="/products?sizeCategory=<%= sc.slug %>"
       class="size-cat-card <%= activeSlug === sc.slug ? 'active' : '' %>">
      <div class="size-cat-icon">
        <%- buildPersonSVG(sc.icon) %>
      </div>
      <div class="size-cat-info">
        <span class="size-cat-label"><%= sc.label %></span>
        <span class="size-cat-dim"><%= sc.sizeLabel %></span>
      </div>
    </a>
  <% }); %>
</div>

<style>
.size-cats-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12px;
  margin-bottom: 32px;
}
.size-cat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 10px;
  border-radius: 10px;
  background: var(--linen-50);
  border: 2px solid var(--linen-200);
  text-align: center;
  transition: all 0.18s;
  cursor: pointer;
  text-decoration: none;
  color: var(--ink-700);
}
.size-cat-card:hover {
  border-color: var(--honey-500);
  background: var(--white);
  color: var(--ink-900);
  box-shadow: 0 4px 16px -4px rgba(255,192,0,0.25);
}
.size-cat-card.active {
  border-color: var(--ink-900);
  background: var(--ink-900);
  color: var(--white);
}
.size-cat-icon {
  width: 48px;
  height: 48px;
  color: currentColor;
}
.size-cat-label {
  font-size: 0.78rem;
  font-weight: 700;
  display: block;
  line-height: 1.3;
}
.size-cat-dim {
  font-size: 0.68rem;
  color: var(--ink-500);
  display: block;
  font-family: 'Space Grotesk', sans-serif;
}
.size-cat-card.active .size-cat-dim {
  color: rgba(255,255,255,0.65);
}
@media (max-width: 900px) {
  .size-cats-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 480px) {
  .size-cats-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
