<% pageTitle = 'تماس با ما' %>
<%- include('partials/header') %>

<div class="container">
  <div class="page-hero" style="padding-bottom:0;">
    <span class="eyebrow">تماس با ما</span>
    <h1>سوالی دارید؟</h1>
  </div>

  <div class="contact-wrap">
    <div class="contact-info-card">
      <h3>راه‌های ارتباطی</h3>
      <div class="info-row"><b>تلفن</b><span><%= content.contact.phone %></span></div>
      <div class="info-row"><b>واتساپ</b><span><%= content.contact.whatsapp %></span></div>
      <div class="info-row"><b>آدرس</b><span><%= content.contact.address %></span></div>
      <div class="info-row"><b>ساعت کاری</b><span><%= content.contact.hours %></span></div>
    </div>

    <form method="POST" action="/contact">
      <% if (sent) { %><div class="notice">پیام شما ثبت شد؛ به‌زودی تماس می‌گیریم.</div><% } %>
      <div class="field">
        <label for="name">نام و نام خانوادگی</label>
        <input type="text" id="name" name="name" required>
      </div>
      <div class="field">
        <label for="phone">شماره تماس</label>
        <input type="tel" id="phone" name="phone" required>
      </div>
      <div class="field">
        <label for="message">پیام شما</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary btn-full">ارسال پیام</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
