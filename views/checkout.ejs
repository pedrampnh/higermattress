<% pageTitle = 'تکمیل خرید' %>
<%- include('partials/header') %>

<div class="container">
  <div class="page-hero" style="padding-bottom:0;">
    <span class="eyebrow">مرحله پایانی</span>
    <h1>اطلاعات ارسال و پرداخت</h1>
  </div>

  <div class="checkout-grid">
    <form class="checkout-form" action="/checkout" method="POST">
      <% if (error) { %><div class="error-notice"><%= error %></div><% } %>
      <div class="field">
        <label for="name">نام و نام خانوادگی</label>
        <input type="text" id="name" name="name" required placeholder="مثلاً: علی رضایی">
      </div>
      <div class="field">
        <label for="phone">شماره تماس</label>
        <input type="tel" id="phone" name="phone" required placeholder="09xxxxxxxxx">
      </div>
      <div class="field">
        <label for="address">آدرس کامل تحویل</label>
        <textarea id="address" name="address" required placeholder="استان، شهر، خیابان، پلاک، واحد"></textarea>
      </div>
      <div class="field">
        <label for="email">ایمیل (اختیاری)</label>
        <input type="email" id="email" name="email" placeholder="example@email.com">
      </div>
      <button type="submit" class="btn btn-primary btn-full">پرداخت آنلاین از طریق زرین‌پال ←</button>
      <p class="security-note">با کلیک روی دکمه پرداخت، به درگاه امن زرین‌پال منتقل می‌شوید. اطلاعات کارت شما هرگز در سایت هیگر ذخیره نمی‌شود.</p>
    </form>

    <div class="order-summary">
      <h3 style="margin-bottom:14px;">خلاصه سفارش</h3>
      <% lines.forEach(function(l){ %>
        <div class="line">
          <span><%= l.faName %> (<%= l.size.replace('x',' × ') %>) × <%= l.qty %></span>
          <span><%= formatToman(l.lineTotal) %></span>
        </div>
      <% }) %>
      <div class="line total-line">
        <span>جمع کل</span>
        <span><%= formatToman(total) %></span>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
