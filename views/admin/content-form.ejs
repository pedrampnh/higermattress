<% pageTitle = 'متن سایت' %>
<%- include('../partials/admin-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
  <div>
    <div class="admin-page-title">ویرایش متن و محتوای سایت</div>
    <div class="admin-page-subtitle">تمام متن‌های قابل ویرایش سایت از اینجا مدیریت می‌شوند</div>
  </div>
</div>

<% if (saved) { %>
  <div class="alert alert-success">✅ تغییرات با موفقیت ذخیره شد!</div>
<% } %>

<form method="POST" action="/admin/content">
  <div class="admin-form-card" style="max-width:900px;">

    <!-- صفحه اصلی -->
    <div class="form-section">
      <div class="form-section-title">🏠 صفحه اصلی (Hero)</div>
      <div class="field" style="margin-bottom:12px;">
        <label for="home_eyebrow">برچسب کوچک بالای عنوان</label>
        <input type="text" id="home_eyebrow" name="home_eyebrow" value="<%= content.home.eyebrow %>" placeholder="مثلاً: تشک باکیفیت ایرانی">
      </div>
      <div class="field" style="margin-bottom:12px;">
        <label for="home_title">عنوان اصلی</label>
        <input type="text" id="home_title" name="home_title" value="<%= content.home.title %>" placeholder="عنوان بزرگ صفحه اول">
      </div>
      <div class="field">
        <label for="home_subtitle">توضیح زیر عنوان</label>
        <textarea id="home_subtitle" name="home_subtitle" rows="3" placeholder="توضیح کوتاه درباره فروشگاه"><%= content.home.subtitle %></textarea>
      </div>
    </div>

    <!-- اطلاعات تماس -->
    <div class="form-section">
      <div class="form-section-title">📞 اطلاعات تماس</div>
      <div class="form-row" style="margin-bottom:12px;">
        <div class="field">
          <label for="contact_phone">شماره تلفن</label>
          <input type="text" id="contact_phone" name="contact_phone" value="<%= content.contact.phone %>" placeholder="021-XXXXXXXX">
        </div>
        <div class="field">
          <label for="contact_whatsapp">شماره واتساپ (با کد کشور، بدون +)</label>
          <input type="text" id="contact_whatsapp" name="contact_whatsapp" value="<%= content.contact.whatsapp %>" placeholder="989XXXXXXXXX">
        </div>
      </div>
      <div class="form-row">
        <div class="field">
          <label for="contact_address">آدرس</label>
          <input type="text" id="contact_address" name="contact_address" value="<%= content.contact.address %>" placeholder="آدرس فروشگاه">
        </div>
        <div class="field">
          <label for="contact_hours">ساعات کاری</label>
          <input type="text" id="contact_hours" name="contact_hours" value="<%= content.contact.hours %>" placeholder="شنبه تا چهارشنبه ۹ تا ۱۸">
        </div>
      </div>
    </div>

    <!-- فوتر -->
    <div class="form-section">
      <div class="form-section-title">📝 فوتر سایت</div>
      <div class="field">
        <label for="footer_line1">متن کپی‌رایت</label>
        <input type="text" id="footer_line1" name="footer_line1" value="<%= content.footer.line1 %>" placeholder="© هیگر مترس. تمامی حقوق محفوظ است.">
      </div>
    </div>

    <!-- درجه‌های کیفی -->
    <div class="form-section">
      <div class="form-section-title">⭐ توضیحات درجه‌های کیفی</div>
      <% [1,2,3,4].forEach(function(t){ %>
        <div style="margin-bottom:16px; padding:14px; background:var(--linen-50); border-radius:8px;">
          <div style="font-size:0.8rem; font-weight:700; color:var(--ink-500); margin-bottom:10px;">درجه <%= t %></div>
          <div class="form-row">
            <div class="field">
              <label for="tier<%= t %>_label">عنوان درجه <%= t %></label>
              <input type="text" id="tier<%= t %>_label" name="tier<%= t %>_label" value="<%= content.tiers[t] ? content.tiers[t].label : '' %>" placeholder="مثلاً: پایه / متوسط / پیشرفته / ممتاز">
            </div>
            <div class="field">
              <label for="tier<%= t %>_desc">توضیح درجه <%= t %></label>
              <input type="text" id="tier<%= t %>_desc" name="tier<%= t %>_desc" value="<%= content.tiers[t] ? content.tiers[t].desc : '' %>" placeholder="توضیح کوتاه درباره این درجه">
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <div style="display:flex; gap:12px;">
      <button type="submit" class="btn btn-primary">💾 ذخیره همه تغییرات</button>
      <a href="/admin" class="btn btn-ghost">انصراف</a>
    </div>

  </div>
</form>

<%- include('../partials/admin-footer') %>
