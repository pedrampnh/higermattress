<% pageTitle = 'محصولات' %>
<%- include('../partials/admin-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
  <div>
    <div class="admin-page-title">مدیریت محصولات</div>
    <div class="admin-page-subtitle"><%= products.length %> محصول در سیستم ثبت شده</div>
  </div>
  <a href="/admin/products/new" class="btn btn-primary">➕ محصول جدید</a>
</div>

<!-- جستجو -->
<div class="admin-search-bar">
  <input type="text" id="productSearch" placeholder="جستجو در نام محصولات..." oninput="filterTable()">
  <select id="categoryFilter" onchange="filterTable()" style="padding:9px 14px; border:1.5px solid var(--linen-200); border-radius:6px; font-size:0.86rem; color:var(--ink-900);">
    <option value="">همه دسته‌بندی‌ها</option>
    <option value="spring-pocket">فنر منفصل</option>
    <option value="spring-bonnell">فنر متصل</option>
    <option value="foam">اسفنجی</option>
    <option value="memory-foam">مموری فوم</option>
  </select>
</div>

<div class="admin-section">
  <div class="admin-section-body">
    <table class="admin-table" id="productsTable">
      <thead>
        <tr>
          <th>#</th>
          <th>نام محصول</th>
          <th>دسته‌بندی</th>
          <th>درجه</th>
          <th>قیمت ۱۶۰×۲۰۰</th>
          <th>عملیات</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(p, i){ %>
          <tr data-name="<%= (p.faName + ' ' + p.enName).toLowerCase() %>" data-cat="<%= p.category %>">
            <td class="muted"><%= i + 1 %></td>
            <td>
              <strong><%= p.faName %></strong>
              <div class="muted"><%= p.enName %></div>
            </td>
            <td>
              <span class="tag <%= p.category === 'spring-pocket' || p.category === 'spring-bonnell' ? 'tag-spring' : p.category === 'memory-foam' ? 'tag-memory' : 'tag-foam' %>">
                <%= p.category === 'spring-pocket' ? 'فنر منفصل' :
                    p.category === 'spring-bonnell' ? 'فنر متصل' :
                    p.category === 'memory-foam' ? 'مموری فوم' :
                    p.category === 'foam' ? 'اسفنجی' : p.category %>
              </span>
            </td>
            <td>
              <span class="tag">درجه <%= p.tier %></span>
            </td>
            <td>
              <strong><%= formatToman(p.prices['160x200']) %></strong>
            </td>
            <td>
              <div class="row-actions">
                <a href="/product/<%= p.slug %>" target="_blank" class="link-btn" title="مشاهده در سایت">🌐</a>
                <a href="/admin/products/<%= p.slug %>/edit" class="link-btn" title="ویرایش">✏️ ویرایش</a>
                <form action="/admin/products/<%= p.slug %>/delete" method="POST" onsubmit="return confirm('محصول «<%= p.faName %>» حذف شود؟');" style="display:inline;">
                  <button type="submit" class="link-btn danger" title="حذف">🗑 حذف</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">🛏</div>
        <h3>هنوز محصولی اضافه نشده</h3>
        <p>اولین محصول خود را اضافه کنید</p>
        <a href="/admin/products/new" class="btn btn-primary" style="margin-top:14px;">➕ افزودن محصول</a>
      </div>
    <% } %>
  </div>
</div>

<script>
function filterTable() {
  const search = document.getElementById('productSearch').value.toLowerCase();
  const cat = document.getElementById('categoryFilter').value;
  document.querySelectorAll('#productsTable tbody tr').forEach(function(row) {
    const name = row.dataset.name || '';
    const rowCat = row.dataset.cat || '';
    const matchSearch = !search || name.includes(search);
    const matchCat = !cat || rowCat === cat;
    row.style.display = (matchSearch && matchCat) ? '' : 'none';
  });
}
</script>

<%- include('../partials/admin-footer') %>
