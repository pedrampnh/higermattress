<% pageTitle = product.faName %>
<%- include('partials/header') %>

<div class="container">
  <div class="product-detail">
    <div class="pd-visual"><%= product.enName.toUpperCase() %></div>
    <div class="pd-info">
      <span class="eyebrow"><%= tierInfo.label %> · <%= categoryLabel %></span>
      <h1><%= product.faName %></h1>
      <div class="en-name"><%= product.enName %></div>
      <p class="tier-desc"><%= tierInfo.desc %></p>

      <table class="size-table">
        <thead>
          <tr><th>سایز (سانتی‌متر)</th><th>قیمت</th></tr>
        </thead>
        <tbody>
          <% SIZES.forEach(function(s){ %>
            <tr>
              <td><%= s.replace('x',' × ') %></td>
              <td><%= formatToman(product.prices[s]) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <form class="add-form" action="/cart/add" method="POST" id="addForm">
        <input type="hidden" name="slug" value="<%= product.slug %>">
        <div class="field-inline">
          <label for="size">سایز</label>
          <select name="size" id="sizeSelect">
            <% SIZES.forEach(function(s){ %>
              <option value="<%= s %>" data-price="<%= product.prices[s] %>" <%= s==='160x200' ? 'selected' : '' %>>
                <%= s.replace('x',' × ') %> سانتی‌متر
              </option>
            <% }) %>
          </select>
        </div>
        <div class="field-inline">
          <label for="qty">تعداد</label>
          <input type="number" name="qty" id="qty" value="1" min="1" style="min-width:70px;">
        </div>
        <div class="price-display" id="priceDisplay"><%= formatToman(product.prices['160x200']) %></div>
        <button type="submit" class="btn btn-primary">افزودن به سبد خرید</button>
      </form>
    </div>
  </div>
</div>

<script>
  const sizeSelect = document.getElementById('sizeSelect');
  const priceDisplay = document.getElementById('priceDisplay');
  const fmt = new Intl.NumberFormat('fa-IR');
  sizeSelect.addEventListener('change', () => {
    const opt = sizeSelect.options[sizeSelect.selectedIndex];
    priceDisplay.textContent = fmt.format(opt.dataset.price) + ' تومان';
  });
</script>

<%- include('partials/footer') %>
